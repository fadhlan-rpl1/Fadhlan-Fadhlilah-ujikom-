CREATE TABLE IF NOT EXISTS "migrations" ("id" integer primary key autoincrement not null, "migration" varchar not null, "batch" integer not null);
CREATE TABLE sqlite_sequence(name,seq);
CREATE TABLE IF NOT EXISTS "users" ("id" integer primary key autoincrement not null, "nama_lengkap" varchar not null, "username" varchar not null, "password" varchar not null, "role" varchar check ("role" in ('admin', 'petugas', 'owner')) not null, "created_at" datetime, "updated_at" datetime);
CREATE UNIQUE INDEX "users_username_unique" on "users" ("username");
CREATE TABLE IF NOT EXISTS "tb_tarif" ("id" integer primary key autoincrement not null, "jenis_kendaraan" varchar not null, "tarif_per_jam" integer not null, "created_at" datetime, "updated_at" datetime);
CREATE TABLE IF NOT EXISTS "tb_area_parkir" ("id" integer primary key autoincrement not null, "nama_area" varchar not null, "kapasitas" integer not null, "terisi" integer not null default '0', "created_at" datetime, "updated_at" datetime);
CREATE TABLE IF NOT EXISTS "tb_kendaraan" ("id" integer primary key autoincrement not null, "plat_nomor" varchar not null, "jenis_kendaraan" varchar not null, "user_id" integer, "created_at" datetime, "updated_at" datetime, foreign key("user_id") references "users"("id") on delete set null);
CREATE UNIQUE INDEX "tb_kendaraan_plat_nomor_unique" on "tb_kendaraan" ("plat_nomor");
CREATE TABLE IF NOT EXISTS "tb_transaksi" ("id" integer primary key autoincrement not null, "plat_nomor" varchar not null, "waktu_masuk" datetime not null, "waktu_keluar" datetime, "biaya_total" integer not null default '0', "status" varchar check ("status" in ('masuk', 'keluar')) not null default 'masuk', "durasi_jam" integer not null default '0', "tarif_id" integer, "user_id" integer, "area_parkir_id" integer, "created_at" datetime, "updated_at" datetime, foreign key("tarif_id") references "tb_tarif"("id") on delete set null, foreign key("user_id") references "users"("id") on delete set null, foreign key("area_parkir_id") references "tb_area_parkir"("id") on delete set null);
CREATE TABLE IF NOT EXISTS "activity_logs" ("id" integer primary key autoincrement not null, "user_id" integer not null, "aktivitas" varchar not null, "created_at" datetime, "updated_at" datetime, foreign key("user_id") references "users"("id") on delete cascade);
